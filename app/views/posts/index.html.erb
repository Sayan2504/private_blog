<% content_for :title, "The Blog — Stories & Ideas" %>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">

  <!-- Tabs -->
  <%= render TabsComponent.new(tabs: [
    TabsComponent::Tab.new(label: "Published (#{@published_count})", href: posts_path(tab: "published"), active: @tab == "published"),
    TabsComponent::Tab.new(label: "Drafts (#{@drafts_count})", href: posts_path(tab: "drafts"), active: @tab == "drafts")
  ]) %>

  <% if @posts.any? %>
    <div class="divide-y divide-gray-100">
      <% @posts.each do |post| %>
        <%= render PostCardComponent.new(post: post) %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16">
      <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
      </svg>
      <% if @tab == "drafts" %>
        <h3 class="text-base font-medium text-gray-900 mb-1">No drafts</h3>
        <p class="text-sm text-gray-500 mb-6">Posts saved without publishing will appear here.</p>
      <% else %>
        <h3 class="text-base font-medium text-gray-900 mb-1">No stories yet</h3>
        <p class="text-sm text-gray-500 mb-6">Get started by writing your first post.</p>
      <% end %>
      <%= render ButtonComponent.new(variant: :primary, size: :md, href: new_post_path) do %>
        Write your first story
      <% end %>
    </div>
  <% end %>
</div>
