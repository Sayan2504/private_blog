<%= form_with(model: post, class: "space-y-6") do |form| %>
  <% if post.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
      <div class="flex items-center space-x-2 mb-2">
        <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <h3 class="text-sm font-medium text-red-800"><%= pluralize(post.errors.count, "error") %> prohibited this post from being saved:</h3>
      </div>
      <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
        <% post.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <!-- Title -->
  <div>
    <%= form.text_field :title,
      placeholder: "Title",
      class: "w-full text-4xl font-bold text-gray-900 placeholder-gray-300 border-0 focus:ring-0 focus:outline-none p-0",
      autofocus: true %>
  </div>

  <!-- Subtitle -->
  <div>
    <%= form.text_field :subtitle,
      placeholder: "Write a subtitle...",
      class: "w-full text-xl text-gray-500 placeholder-gray-300 border-0 focus:ring-0 focus:outline-none p-0" %>
  </div>

  <!-- Author -->
  <div>
    <%= form.text_field :author,
      placeholder: "Author name",
      class: "w-full text-sm text-gray-700 placeholder-gray-300 border-0 focus:ring-0 focus:outline-none p-0" %>
  </div>

  <!-- Divider -->
  <hr class="border-gray-100">

  <!-- Content (Rich Text) -->
  <div>
    <%= form.rich_textarea :content, class: "w-full min-h-[400px] prose prose-lg max-w-none" %>
  </div>

  <!-- Actions -->
  <div class="flex items-center justify-between pt-6 border-t border-gray-100">
    <div class="flex items-center space-x-3">
      <%= render ButtonComponent.new(variant: :secondary, size: :lg, type: "submit") do %>
        Save Draft
      <% end %>
      <%= render ButtonComponent.new(variant: :success, size: :lg, type: "submit", name: "publish", value: "true") do %>
        Publish
      <% end %>
    </div>
    <%= render ButtonComponent.new(variant: :ghost, size: :md, href: posts_path) do %>
      Cancel
    <% end %>
  </div>
<% end %>
