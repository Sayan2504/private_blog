<div class="min-h-screen flex items-center justify-center px-4 py-12">
  <div class="w-full max-w-md rounded-3xl border border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-950 p-8 shadow-sm">
    <div class="space-y-2 mb-8">
      <p class="text-sm uppercase tracking-[0.2em] text-gray-500 dark:text-gray-400">Welcome back</p>
      <h1 class="text-3xl font-semibold tracking-tight text-gray-900 dark:text-gray-100">Sign in to MindCanvas</h1>
      <p class="text-sm text-gray-600 dark:text-gray-300">Access your dashboard and manage your stories.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), local: true) do |f| %>
      <div class="space-y-5">
        <div>
          <%= f.label :email, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 px-4 py-2.5 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-gray-900 dark:focus:border-gray-100 transition-colors" %>
        </div>

        <div>
          <%= f.label :password, class: "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 px-4 py-2.5 text-gray-900 dark:text-gray-100 placeholder-gray-400 dark:placeholder-gray-500 focus:outline-none focus:border-gray-900 dark:focus:border-gray-100 transition-colors" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center">
            <%= f.check_box :remember_me, { class: "rounded border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-900 text-gray-900 dark:text-gray-100 focus:outline-none" } %>
            <%= f.label :remember_me, "Keep me signed in", class: "ml-2 text-sm text-gray-700 dark:text-gray-300" %>
          </div>
        <% end %>

        <div class="pt-2">
          <%= f.submit "Sign in", class: "w-full rounded-lg bg-gray-900 px-4 py-2.5 font-medium text-white hover:bg-gray-700 transition-colors dark:bg-gray-100 dark:text-gray-900 dark:hover:bg-gray-300" %>
        </div>
      </div>
    <% end %>

    <div class="mt-6 border-t border-gray-200 dark:border-gray-700 pt-6 space-y-3">
      <% if devise_mapping.recoverable? %>
        <p class="text-center text-sm">
          <%= link_to "Forgot your password?", new_password_path(resource_name), class: "text-gray-600 dark:text-gray-300 hover:text-gray-900 dark:hover:text-gray-100 hover:underline" %>
        </p>
      <% end %>
      <p class="text-center text-sm text-gray-600 dark:text-gray-300">
        Don't have an account?
        <%= link_to "Sign up", new_registration_path(resource_name), class: "font-medium text-gray-900 dark:text-gray-100 hover:underline" %>
      </p>
    </div>
  </div>
</div>
