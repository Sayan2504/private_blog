<nav class="flex space-x-1 border-b border-gray-200 mb-8">
  <% @tabs.each do |tab| %>
    <% classes = tab.active \
      ? "px-4 py-2.5 text-sm font-medium text-gray-900 border-b-2 border-gray-900 -mb-px" \
      : "px-4 py-2.5 text-sm font-medium text-gray-500 hover:text-gray-700 border-b-2 border-transparent hover:border-gray-300 -mb-px transition-colors" %>
    <%= link_to tab.label, tab.href, class: classes %>
  <% end %>
</nav>
