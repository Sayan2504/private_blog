<article class="py-8 group">
  <%= link_to post_path(post), class: "block" do %>
    <div class="flex flex-col space-y-3">
      <!-- Author & Date -->
      <div class="flex items-center space-x-2 text-sm">
        <%= render AvatarComponent.new(name: post.author, size: :sm) %>
        <span class="font-medium text-gray-700"><%= post.author.presence || "Anonymous" %></span>
        <span class="text-gray-300">&middot;</span>
        <% if post.published? %>
          <time class="text-gray-500"><%= post.published_at.strftime("%b %-d, %Y") %></time>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 text-yellow-800">Draft</span>
        <% end %>
      </div>

      <!-- Title & Subtitle -->
      <h2 class="text-xl font-bold text-gray-900 group-hover:text-gray-600 transition-colors leading-tight">
        <%= post.title %>
      </h2>
      <% if post.subtitle.present? %>
        <p class="text-gray-500 leading-relaxed line-clamp-2"><%= post.subtitle %></p>
      <% end %>

      <!-- Meta -->
      <div class="flex items-center justify-between pt-2">
        <div class="flex items-center space-x-3 text-sm text-gray-500">
          <span><%= post.reading_time %> min read</span>
        </div>
        <div class="flex items-center space-x-2">
          <%= render ButtonComponent.new(variant: :ghost, size: :sm, href: edit_post_path(post), icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>') do %>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</article>
