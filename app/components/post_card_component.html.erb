<article class="py-8 group">
  <div class="flex flex-col space-y-3">
    <%= link_to post_path(post), class: "block" do %>
      <!-- Author & Date -->
      <div class="flex items-center space-x-2 text-sm">
        <%= render AvatarComponent.new(name: post.author, size: :sm) %>
        <span class="font-medium text-gray-700 dark:text-gray-300"><%= post.author.presence || "Anonymous" %></span>
        <span class="text-gray-300 dark:text-gray-600">&middot;</span>
        <% if post.published? %>
          <time class="text-gray-500 dark:text-gray-400"><%= post.published_at.strftime("%b %-d, %Y") %></time>
        <% else %>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-yellow-100 dark:bg-yellow-900 text-yellow-800 dark:text-yellow-200">Draft</span>
        <% end %>
      </div>

      <!-- Title -->
      <h2 class="text-xl font-bold text-gray-900 dark:text-gray-100 group-hover:text-gray-600 dark:group-hover:text-gray-300 transition-colors leading-tight mt-3">
        <%= post.title %>
      </h2>
    <% end %>

    <!-- Meta -->
    <div class="flex items-center justify-between pt-2">
      <div class="flex items-center space-x-3 text-sm text-gray-500 dark:text-gray-400">
        <span><%= post.reading_time %> min read</span>
      </div>
      <div class="flex items-center space-x-3">
        <%= link_to edit_post_path(post), class: "text-gray-400 dark:text-gray-500 hover:text-gray-600 dark:hover:text-gray-300 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        <% end %>
        <%= link_to post_path(post), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this post?" }, class: "text-red-400 dark:text-red-500 hover:text-red-600 dark:hover:text-red-400 transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</article>
