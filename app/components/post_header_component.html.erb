<header class="mb-8">
  <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-gray-900 dark:text-gray-100 leading-tight mb-4">
    <%= post.title %>
  </h1>

  <!-- Author Info -->
  <div class="flex items-center justify-between border-t border-b border-gray-100 dark:border-gray-700 py-4">
    <div class="flex items-center space-x-3">
      <%= render AvatarComponent.new(name: post.author, size: :lg) %>
      <div>
        <p class="text-sm font-medium text-gray-900 dark:text-gray-100"><%= post.author.presence || "Anonymous" %></p>
        <div class="flex items-center space-x-2 text-sm text-gray-500 dark:text-gray-400">
          <time><%= post.published_at&.strftime("%B %-d, %Y") || "Draft" %></time>
          <span>&middot;</span>
          <span><%= post.reading_time %> min read</span>
        </div>
      </div>
    </div>

    <div class="flex items-center space-x-2">
      <%= render ButtonComponent.new(variant: :ghost, size: :sm, href: edit_post_path(post), icon: '<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>') do %>
        Edit
      <% end %>
      <%= button_to post_path(post), method: :delete, class: "inline-flex items-center font-medium rounded-md cursor-pointer transition-colors bg-transparent text-red-500 hover:text-red-700 border-0 px-3 py-1.5 text-xs", data: { turbo_confirm: "Are you sure you want to delete this post?" } do %>
        <svg class="w-4 h-4 mr-1.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/>
        </svg>
        Delete
      <% end %>
    </div>
  </div>
</header>
